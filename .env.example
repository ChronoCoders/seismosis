# ============================================================
# Seismosis — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in real values.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# .env is in .gitignore.
# ============================================================

# ─── PostgreSQL ──────────────────────────────────────────────
# Database name, created on first boot by the postgres container.
POSTGRES_DB=seismosis

# Database superuser for the seismosis application.
# This user is created with CREATEDB and CREATEROLE privileges.
POSTGRES_USER=seismosis

# Strong password required. This value is used in:
#   - PostgreSQL authentication
#   - postgres-exporter DATA_SOURCE_NAME
# Minimum 20 characters in production.
POSTGRES_PASSWORD=change_me_before_production_use

# ─── Redis ───────────────────────────────────────────────────
# Password for Redis AUTH command.
# Must match the 'requirepass' value in config/redis/redis.conf.
# Leave empty to disable Redis authentication (dev only).
REDIS_PASSWORD=

# ─── Grafana ─────────────────────────────────────────────────
# Initial admin account. Change the password after first login.
GRAFANA_ADMIN_USER=admin

# Minimum 12 characters. Grafana will reject passwords that are
# too similar to the username.
GRAFANA_ADMIN_PASSWORD=change_me_before_production_use

# ─── Application Services ────────────────────────────────────
# Used by Rust and Python services to connect to infrastructure.
# These are the internal Docker network addresses.

# Kafka bootstrap server (internal Docker network)
KAFKA_BROKERS=redpanda:9092

# Schema Registry (internal Docker network)
SCHEMA_REGISTRY_URL=http://redpanda:8081

# PostgreSQL DSN (internal Docker network)
DATABASE_URL=postgresql://seismosis:${POSTGRES_PASSWORD}@postgres:5432/seismosis

# Redis URL (internal Docker network)
REDIS_URL=redis://redis:6379

# ─── Observability ───────────────────────────────────────────
# Prometheus remote write (leave empty to disable remote write)
PROMETHEUS_REMOTE_WRITE_URL=

# Log level for all services: trace | debug | info | warn | error
LOG_LEVEL=info

# ─── Seismic Data Sources ────────────────────────────────────
# USGS Earthquake Catalog API (public, no key required for basic use)
USGS_API_BASE_URL=https://earthquake.usgs.gov/fdsnws/event/1

# EMSC (European-Mediterranean Seismological Centre) feed URL
EMSC_FEED_URL=https://www.seismicportal.eu/fdsnws/event/1

# AFAD (Turkish Disaster and Emergency Management Authority) API base URL.
# IMPORTANT: do NOT include /filter in this value — the service appends it.
# Correct:   https://deprem.afad.gov.tr/apiv2/event
# Incorrect: https://deprem.afad.gov.tr/apiv2/event/filter
AFAD_API_BASE_URL=https://deprem.afad.gov.tr/apiv2/event

# Polling interval for external data sources (seconds)
SOURCE_POLL_INTERVAL_SECS=60

# Minimum magnitude to ingest (filter noisy micro-events in dev)
# Set to 0.0 to ingest all events
MIN_MAGNITUDE_INGEST=2.0

# ─── Feature Flags ───────────────────────────────────────────
# All flags default to off; enable per-environment as needed.
ENABLE_ALERT_NOTIFICATIONS=false
ENABLE_REDIS_CACHE=true
ENABLE_SCHEMA_VALIDATION=true
